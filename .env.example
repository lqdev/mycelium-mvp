# Mycelium MVP — Environment Variables
# Copy to .env or export these vars before running.
# All variables are optional — the default is zero-config simulation mode.

# ─── LLM Inference ────────────────────────────────────────────────────────────
# Enable real LLM inference (default: simulation mode)
# MYCELIUM_ENABLE_INFERENCE=true

# Option A: GitHub Models (free — get token at https://github.com/settings/tokens)
# GITHUB_TOKEN=ghp_...

# Option B: Local Ollama (install at https://ollama.ai, then: ollama pull qwen2.5:7b)
# Routes ALL agents through this local model (overrides per-agent model assignments)
# LOCAL_ONLY_MODEL=qwen2.5:7b

# Increase timeout when using slower local models (default: 150000ms)
# DEMO_TIMEOUT_MS=600000

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ─── AT Protocol (Phase 12c — PDS Bridge) ────────────────────────────────────
# Mirror agent records to a local AT Protocol PDS
# Run: npm run pds-init  then: docker compose --profile pds up
# PDS_ENDPOINT=http://localhost:2583
# PDS_ADMIN_PASSWORD=changeme

# ─── AT Protocol (Phase 12d — Jetstream Federation) ──────────────────────────
# Subscribe to a Jetstream relay to see network.mycelium.* events from other nodes
# Use with: docker compose --profile pds --profile jetstream up
# JETSTREAM_ENDPOINT=ws://localhost:6008/subscribe
